# ======================================
# AI Interview Training App - 환경변수
# ======================================
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요.
# cp .env.example .env

# --- OpenAI ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx

# --- Daglo STT (선택: Daglo 음성인식 사용 시 필요) ---
DAGLO_API_KEY=xxxxxxxxxxxx

# --- Supabase (인증 + 사용량 관리) ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx

# --- JWT (인증 토큰 서명용, 32자 이상 랜덤 문자열) ---
JWT_SECRET=your-random-secret-string-at-least-32-chars

# --- Upstash Redis (분산 Rate Limiting - 선택, 없으면 인메모리 폴백) ---
# Vercel 멀티 인스턴스 배포 시 전역 Rate Limiting을 위해 권장
# https://console.upstash.com → Redis Database 생성 후 REST URL/Token 복사
# UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxx

# --- Admin Dashboard (관리자 비밀번호) ---
ADMIN_PASSWORD=your-admin-password-here

# --- 개발자 모드 (로컬에서만 true로 설정, 배포 시 생략) ---
# NEXT_PUBLIC_DEV_MODE_ENABLED=true

# --- ERP 학생 정보 연동 (2026-04-22~) ---
# 엔드포인트: {ERP_BASE_URL}/api/external/interview/students
# 상세: docs/ERP_연동_합의서_최종.md
# 현재 ERP는 Vercel stable alias: https://erp-lilac-three.vercel.app
# (향후 erp.evenigame.com DNS/SSL 복구 시에도 기존 URL 유효)
ERP_BASE_URL=https://erp-lilac-three.vercel.app
ERP_API_KEY=replace-with-erp-issued-bearer-token

# Dry-run 모드: true 면 실제 DB 변경 없이 검증 로그만 출력 (초기 이관 검증용)
ERP_DRY_RUN=true

# Vercel Cron 호출 인증용 (Authorization: Bearer ${CRON_SECRET})
# 32자 이상 랜덤 문자열 권장 (openssl rand -hex 32)
CRON_SECRET=replace-with-random-secret-at-least-32-chars

# 초기 이관 시작 시각 (ISO8601, KST 오프셋 권장)
ERP_INITIAL_UPDATED_AFTER=2020-01-01T00:00:00+09:00

# 1회 실행당 최대 페이지 수 (페이지당 최대 500건)
# Vercel Cron 60초 제한 고려 — 초기 이관은 scripts/erp-initial-pull.js 로 별도 수행
ERP_MAX_PAGES_PER_RUN=10
